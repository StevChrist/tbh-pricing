# TBH Inventory Price Tracker — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.

# ===== Application =====
APP_NAME="TBH Inventory Price Tracker"
DEBUG=false

# ===== Security =====
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ===== CORS =====
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ===== Steam =====
STEAM_APP_ID=3678970
STEAM_REQUEST_DELAY_SECONDS=3

# ===== Scheduler =====
REFRESH_INTERVAL_MINUTES=15

# ===== Database =====
# Local database connection (localhost for local dev, overridden in docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tbh_price
